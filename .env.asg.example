# =========================================================================
# TEMPLATE ENVIRONMENT VARIABLES UNTUK AWS ASG DEPLOYMENT
# =========================================================================
# Salin file ini menjadi '.env' di instance EC2 Anda sebelum menjalankan:
#   docker compose -f docker-compose.asg.yml up -d
# =========================================================================

# Nama/Tag docker image yang akan digunakan (misal dari Amazon ECR)
API_IMAGE=123456789012.dkr.ecr.ap-southeast-1.amazonaws.com/elasticsix-api:latest

# Port host EC2 yang akan di-expose (untuk target group ALB)
HOST_PORT=80

# Kredensial Database
DB_USER=root
DB_PASSWORD=password
DB_NAME=bank_a_db
DB_PORT=5432
DB_REPLICA_PORT=5433

# IP Host/Server Database Terpusat (contoh RDS atau EC2 database server)
DB_HOST=172.31.28.90

# IP Host/Server Redis Cache Terpusat
REDIS_HOST=172.31.28.90
REDIS_PORT=6379

# Kredensial & IP Host/Server RabbitMQ Queue Terpusat
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_HOST=172.31.28.90
RABBITMQ_PORT=5672